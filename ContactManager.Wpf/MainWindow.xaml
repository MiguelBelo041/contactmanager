<Window x:Class="ContactManager.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ContactManager.Wpf.ViewModels"
        xmlns:conv="clr-namespace:ContactManager.Wpf.Converters"
        mc:Ignorable="d"
        Title="ContactManager - Cadastro de Contatos"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13"
        PreviewMouseDown="Window_PreviewMouseDown">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:ShortGuidConverter x:Key="ShortGuid" />
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="90" />
        </Style>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Cadastro de Contatos"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,12" />

        <Border Grid.Row="1"
                BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="4" Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Nome" Style="{StaticResource LabelStyle}" Margin="0,0,8,2" />
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="Sobrenome" Style="{StaticResource LabelStyle}" Margin="4,0,4,2" />
                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="Telefone" Style="{StaticResource LabelStyle}" Margin="8,0,0,2" />

                <TextBox Grid.Row="1" Grid.Column="0"
                         Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding Sobrenome, UpdateSourceTrigger=PropertyChanged}"
                         Margin="4,0,4,0" />
                <TextBox Grid.Row="1" Grid.Column="2"
                         Text="{Binding Telefone, UpdateSourceTrigger=PropertyChanged}"
                         Margin="8,0,0,0"
                         MaxLength="20"
                         PreviewTextInput="Telefone_PreviewTextInput"
                         PreviewKeyDown="Telefone_PreviewKeyDown"
                         DataObject.Pasting="Telefone_Pasting" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Salvar" Command="{Binding SalvarCommand}" />
            <Button Content="Atualizar" Command="{Binding AtualizarCommand}" />
            <Button Content="Excluir" Command="{Binding ExcluirCommand}" />
            <Button Content="Limpar" Command="{Binding LimparCommand}" />
            <Button Content="Recarregar" Command="{Binding RecarregarCommand}" />
        </StackPanel>

        <DataGrid Grid.Row="3"
                  x:Name="ContactsGrid"
                  ItemsSource="{Binding Contatos}"
                  SelectedItem="{Binding ContatoSelecionado}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F7F7F7"
                  RowHeight="28">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Id" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Id, Converter={StaticResource ShortGuid}}"
                                       ToolTip="{Binding Id}"
                                       FontFamily="Consolas"
                                       Foreground="#666"
                                       VerticalAlignment="Center"
                                       Margin="6,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*" />
                <DataGridTextColumn Header="Sobrenome" Binding="{Binding Sobrenome}" Width="*" />
                <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4"
                Background="#EEE" Padding="8,4"
                Margin="0,12,0,0"
                CornerRadius="2">
            <TextBlock Text="{Binding StatusMensagem}" />
        </Border>
    </Grid>
</Window>
